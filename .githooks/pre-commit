#!/bin/bash
# Automated QA gate вЂ” runs on every commit
# Blocks commit if go vet or gofmt find issues

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

echo "в”Ѓв”Ѓв”Ѓ QA Gate: go vet в”Ѓв”Ѓв”Ѓ"
if ! go vet ./...; then
    echo -e "${RED}вњ— go vet failed вЂ” fix errors before committing${NC}"
    exit 1
fi
echo -e "${GREEN}вњ“ go vet passed${NC}"

echo ""
echo "в”Ѓв”Ѓв”Ѓ QA Gate: gofmt в”Ѓв”Ѓв”Ѓ"
unformatted=$(gofmt -l . 2>/dev/null)
if [ -n "$unformatted" ]; then
    echo -e "${RED}вњ— Unformatted files:${NC}"
    echo "$unformatted"
    echo "Run: gofmt -w ."
    exit 1
fi
echo -e "${GREEN}вњ“ gofmt passed${NC}"

echo ""
echo "в”Ѓв”Ѓв”Ѓ QA Gate: go test в”Ѓв”Ѓв”Ѓ"
if ! go test ./... 2>/dev/null; then
    echo -e "${RED}вњ— go test failed${NC}"
    exit 1
fi
echo -e "${GREEN}вњ“ go test passed${NC}"

echo ""
echo -e "${GREEN}All QA gates passed вњ“${NC}"
